----------------------------------
	--DATA SEGMENTATION
---------------------------------
--within cost range
WITH product_segment AS
(SELECT 
product_key,
product_name,
CASE 
	WHEN cost<100 THEN 'Below 100'
	WHEN cost BETWEEN 100 AND 500 THEN '100-500'
	WHEN cost BETWEEN 500 AND 1000 THEN '500-1000'
	ELSE '1000+'
END AS cost_range
FROM gold.dim_products
)
SELECT 
cost_range,
COUNT(product_key) AS total_products
FROM product_segment
GROUP BY cost_range;

--categorize the customers to vip regualar and new & on the basis of spending >5000 + 12 month old customer =VIP 
WITH customer_date_info AS
(SELECT 
customer_key,
MIN(order_date)  AS first_order_date,
MAX(order_date)  AS last_order_date,
SUM(sales_amount) AS spending
FROM gold.fact_sales
WHERE order_date IS NOT NULL
GROUP BY customer_key
)
SELECT customer_key,
spending,
DATEDIFF(MONTH,first_order_date,last_order_date) AS lifespan,
CASE 
	WHEN spending > 5000 AND DATEDIFF(MONTH,first_order_date,last_order_date) >=12 THEN 'VIP'
	WHEN spending <= 5000 AND DATEDIFF(MONTH,first_order_date,last_order_date) >=12 THEN 'REGULAR'
	ELSE 'NEW'
END AS customer_segment
FROM customer_date_info
ORDER BY customer_key
