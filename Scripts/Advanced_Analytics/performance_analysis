---------------------------------------------
	--Performance Analysis
---------------------------------------------

--sales in compare to average sale And previous year sale
WITH yearly_product_sales AS(
SELECT 
YEAR(t1.order_date) AS order_year,
t2.product_name	AS product_name,
SUM(t1.sales_amount) AS total_sales
FROM gold.fact_sales t1
LEFT JOIN gold.dim_products t2
ON t1.product_key = t2.product_key
WHERE order_date IS NOT NULL
GROUP BY YEAR(t1.order_date), t2.product_name
)
SELECT 
order_year,total_sales,product_name,
total_sales  - AVG(total_sales) OVER(PARTITION BY product_name ORDER BY order_year ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS sales_respect_to_current_avg,
total_sales  - LAG(total_sales) OVER(ORDER BY order_year) AS sales_respect_to_last_year,
CASE 
	WHEN total_sales  - AVG(total_sales) OVER(PARTITION BY product_name ORDER BY order_year ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) < 0 THEN 'Below Average'
	WHEN total_sales  - AVG(total_sales) OVER(PARTITION BY product_name ORDER BY order_year ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) > 0 THEN 'Above Average'
	ELSE 'Average'
END AS _average_sale
FROM yearly_product_sales
ORDER BY product_name,order_year;
